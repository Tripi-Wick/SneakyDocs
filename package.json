{
  "name": "collapse-docs",
  "displayName": "Collapse Docs",
  "description": "Quickly collapse or uncollapse all docstrings and JSDoc comments via right-click menu.",
  "publisher": "Oskarlypka",
  "version": "1.4.1",
  "engines": {
    "vscode": "^1.60.0"
  },
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onCommand:collapseDocs.toggle"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "collapseDocs.toggle",
        "title": "Toggle Collapse Docs"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "collapseDocs.toggle",
          "when": "editorLangId == javascript || editorLangId == typescript || editorLangId == javascriptreact || editorLangId == typescriptreact || editorLangId == python",
          "group": "collapseDocsGroup@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "collapseDocs.toggle",
        "key": "ctrl+shift+alt+d",
        "when": "editorTextFocus && (editorLangId == javascript || editorLangId == typescript || editorLangId == javascriptreact || editorLangId == typescriptreact || editorLangId == python)"
      }
    ]
  },
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "icon": "images/icon.png",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "postinstall": "node ./node_modules/vscode/bin/install"
  },
  "devDependencies": {
    "typescript": "^4.0.0",
    "vscode": "^1.1.36"
  }
}
